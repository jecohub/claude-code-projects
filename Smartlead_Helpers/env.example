## Copy this file to `.env` and fill in values.
## IMPORTANT: never commit your `.env`.

# Required: Smartlead public API key (Smartlead UI → Settings → API)
SMARTLEAD_API_KEY=your_api_key_here

# Optional: Smartlead public API base URL
SMARTLEAD_BASE_URL=https://server.smartlead.ai/api/v1

# Optional: Smartlead web app auth token (JWT) used for internal GraphQL calls.
# Enables copying UI-only settings (AI categorisation, bounce auto-protection, OOO settings).
# You can paste with or without the "Bearer " prefix.
# SMARTLEAD_WEB_AUTH_TOKEN=eyJhbGciOi...

# Optional: local lead ledger DB path (SQLite)
# This is the “source of truth” for what you uploaded per campaign, so you never rely on Smartlead exports.
# Default: ./data/lead-ledger.sqlite (relative to Smartlead_Helpers)
# LEAD_LEDGER_DB_PATH=/absolute/path/to/lead-ledger.sqlite

# Optional: request timeout (ms)
# SMARTLEAD_TIMEOUT_MS=120000

# Optional: rate limits (requests per second)
# CAMPAIGN_RATE_LIMIT=50
# LEAD_UPLOAD_RATE_LIMIT=300
# READ_RATE_LIMIT=100

# Optional: concurrency controls
# BATCH_UPLOAD_CONCURRENCY=5
# DUPLICATE_DETECTION_CONCURRENCY=3
# CAMPAIGN_DUPLICATION_CONCURRENCY=2

# Optional: convenience for scripts/local-call.ts
# SMARTLEAD_CLIENT_ID=128520

