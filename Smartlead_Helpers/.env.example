# Smartlead API Configuration
SMARTLEAD_API_KEY=your_api_key_here
SMARTLEAD_BASE_URL=https://server.smartlead.ai/api/v1
SMARTLEAD_TIMEOUT_MS=120000

# Optional: Web authentication token for applying UI-only settings via GraphQL
# These settings (AI categorization, bounce auto-protection, OOO detection) are
# now configured as fixed values in src/campaignUiSettings.ts
# This token is only needed to APPLY those fixed settings, not to copy from source
SMARTLEAD_WEB_AUTH_TOKEN=your_jwt_token_here

# Rate Limiting (requests per second)
# Campaign operations: create, update settings, schedule, sequences
CAMPAIGN_RATE_LIMIT=50

# Lead upload operations: POST to /campaigns/{id}/leads
# Conservative: 300 (API supports 400, but leaving headroom)
LEAD_UPLOAD_RATE_LIMIT=300

# Read operations: GET requests for duplicate detection
READ_RATE_LIMIT=100

# Concurrency Limits
# How many batch uploads to run in parallel (recommended: 5-10)
BATCH_UPLOAD_CONCURRENCY=8

# How many pagination requests for duplicate detection (recommended: 3-5)
DUPLICATE_DETECTION_CONCURRENCY=3

# How many campaigns to duplicate in parallel (recommended: 2)
CAMPAIGN_DUPLICATION_CONCURRENCY=2
