{
  "name": "smartlead-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "local-call": "node --loader ts-node/esm scripts/local-call.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "report": "node --loader ts-node/esm scripts/generate-report.ts",
    "report:json": "node --loader ts-node/esm scripts/generate-report.ts --format=json",
    "analyze": "npx tsx scripts/analyze-campaign-success.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "p-limit": "^7.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
